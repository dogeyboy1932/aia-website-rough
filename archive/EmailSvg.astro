---
import satori from 'satori';
import { getFont } from '../../utils/getFont';

interface Props {
  email: string;
}

const { email } = Astro.props;

let svgString = '';

try {
    const fontData = await getFont();

    svgString = await satori(
    {
        type: 'div',
        props: {
        children: email,
        style: {
            color: '#000000',
            fontSize: '14px', // text-sm
            // Using a standard sans-serif font stack fallback just in case, but Satori uses the font data provided
            fontFamily: 'Inter', 
            display: 'flex',
            alignItems: 'center',
            height: '100%',
        },
        },
    } as any,
    {
        height: 20, // text-sm line-height matches tailwind's 1.25rem = 20px
        fonts: [
        {
            name: 'Inter',
            data: fontData,
            weight: 400,
            style: 'normal',
        },
        ],
    }
    );

    // Replace hardcoded color with currentColor to support hover states
    svgString = svgString.replace(/fill="#000000"/g, 'fill="currentColor"');
} catch (e) {
    console.error(`Error generating email SVG for ${email}:`, e);
    // Fallback?
    svgString = `<!-- Error generating SVG -->`;
}
---

<Fragment set:html={svgString} />
