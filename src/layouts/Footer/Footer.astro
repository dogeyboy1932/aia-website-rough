---
import { LAYOUT_CONFIG, ResourcesUrl, SITE } from '../../config';
import { ArrowUpRight } from 'lucide-react';
---

<footer id="contact" class="relative bg-[#0A0F1A] text-white pt-20 pb-10 border-t border-[#FF5F05]/20 overflow-hidden">
    <!-- Decorative background -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, rgba(255, 95, 5, 0.5) 0%, transparent 70%); filter: blur(80px);"></div>
        <div class="absolute top-0 right-0 w-80 h-80 rounded-full opacity-20" style="background: radial-gradient(circle, rgba(19, 41, 75, 0.6) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-14 mb-14">
            <!-- Quick Links -->
            <div class="space-y-7">
                <h2 class="text-2xl font-bold text-white mb-6 uppercase tracking-wider relative inline-block">
                    Quick Links
                    <span class="absolute -bottom-2 left-0 w-full h-0.5 bg-gradient-to-r from-[#FF5F05] to-transparent"></span>
                </h2>
                <div class="space-y-5">
                    <div>
                        <a href="/team" class="group flex items-center gap-2 text-lg text-gray-400 hover:text-[#FF5F05] transition-all duration-300">
                            Team
                        </a>
                    </div>
                    <div>
                        <a href="/spring-2026" class="group flex items-center gap-2 text-lg text-gray-400 hover:text-[#FF5F05] transition-all duration-300">
                            Get Involved
                        </a>
                    </div>
                    <div>
                        <a href={ResourcesUrl} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-lg text-gray-400 hover:text-[#FF5F05] transition-all duration-300">
                            Resources
                            <ArrowUpRight className="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                        </a>
                    </div>
                </div>
            </div>

            <!-- Connect With Us -->
            <div class="space-y-7">
                <h2 class="text-2xl font-bold text-white mb-6 uppercase tracking-wider relative inline-block">
                    Connect With Us
                    <span class="absolute -bottom-2 left-0 w-full h-0.5 bg-gradient-to-r from-[#FF5F05] to-transparent"></span>
                </h2>
                <ul class="space-y-5">
                    <div>
                        <a href="https://discord.com/invite/hGcu53KNrY" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 text-lg text-gray-400 hover:text-[#FF5F05] transition-all duration-300">
                            <div class="p-2.5 rounded-lg bg-[#13294B]/50 group-hover:bg-[#FF5F05]/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1892.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.1023.2462.1922.3718.2914a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.699.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419z"/></svg>
                            </div>
                            Discord
                            <ArrowUpRight className="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                        </a>
                    </div>
                    <div>
                        <a href="https://www.instagram.com/aialignmentuiuc" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 text-lg text-gray-400 hover:text-[#FF5F05] transition-all duration-300">
                            <div class="p-2.5 rounded-lg bg-[#13294B]/50 group-hover:bg-[#FF5F05]/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                            </div>
                            Instagram
                            <ArrowUpRight className="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                        </a>
                    </div>
                </ul>
            </div>

            <!-- Stay Updated -->
            <div class="space-y-7">
                <h2 class="text-2xl font-bold text-white mb-6 uppercase tracking-wider relative inline-block">
                    Stay Updated
                    <span class="absolute -bottom-2 left-0 w-full h-0.5 bg-gradient-to-r from-[#FF5F05] to-transparent"></span>
                </h2>
                <p class="text-lg text-gray-400 leading-relaxed">Join our mailing list for updates on programs, events, and research.</p>
                <a 
                    href="https://forms.gle/YHxnF3y5LpnxF4s27" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="btn-primary inline-flex items-center gap-2 text-lg text-center"
                >
                    Sign Up
                    <ArrowUpRight className="w-4 h-4" />
                </a>
            </div>
        </div>

        <!-- Bottom bar -->
        <div class="pt-10 border-t border-[#FF5F05]/10 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-base text-gray-500">
                &copy; {new Date().getFullYear()} <span class="text-[#FF5F05]">{SITE.labName}</span>. All rights reserved.
            </p>
            <p class="text-base text-gray-500">
                University of Illinois Urbana-Champaign
            </p>
        </div>
    </div>
</footer>
