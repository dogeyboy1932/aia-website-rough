---
import { Search, ChevronRight } from 'lucide-react';

interface NavItem {
  link: string;
  key: string;
  text: string;
}

interface Props {
  items: NavItem[];
  mode: 'desktop' | 'mobile';
}

const { items, mode } = Astro.props;
const isDesktop = mode === 'desktop';
---

<>
  {items.map((item) => {
    if (isDesktop && item.key === 'search') {
      return (
        <a
          href={item.link}
          class="p-2 text-gray-300 hover:text-[#FF5F05] rounded-full transition-all duration-300 hover:bg-[#FF5F05]/10"
          aria-label={item.text}
        >
          <Search className="w-5 h-5" />
        </a>
      );
    }

    if (isDesktop) {
      return (
        <a
          href={item.link}
          class="relative text-sm font-bold text-gray-300 hover:text-[#FF5F05] transition-all duration-300 uppercase tracking-widest hover-underline group py-2"
          data-i18n-key={`nav.${item.key}`}
        >
          <span class="relative z-10">{item.text}</span>
          <span class="absolute inset-0 rounded-lg bg-[#FF5F05]/0 group-hover:bg-[#FF5F05]/5 transition-colors duration-300"></span>
        </a>
      );
    }

    return (
      <a
        href={item.link}
        class="group flex items-center justify-between w-full py-4 px-4 text-lg font-bold text-gray-100 hover:text-[#FF5F05] transition-all duration-300 border-b border-[#FF5F05]/10 last:border-0 uppercase tracking-wide rounded-lg hover:bg-[#FF5F05]/10"
        data-i18n-key={`nav.${item.key}`}
        @click="$dispatch('menu-close')"
      >
        <span>{item.text}</span>
        <ChevronRight className="w-5 h-5 text-gray-500 group-hover:text-[#FF5F05] group-hover:translate-x-1 transition-all duration-300" />
      </a>
    );
  })}
</>
