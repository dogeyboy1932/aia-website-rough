---
import { Search, ChevronDown } from 'lucide-react';

interface NavItem {
  link: string;
  key: string;
  text: string;
}

interface Props {
  items: NavItem[];
  mode: 'desktop' | 'mobile';
}

const { items, mode } = Astro.props;
const isDesktop = mode === 'desktop';
---

<>
  {items.map((item) => {
    if (isDesktop && item.key === 'search') {
      return (
        <a
          href={item.link}
          class="p-2 text-gray-300 hover:text-[#FF6B35] hover:bg-[#FF6B35]/10 rounded-full transition-colors"
          aria-label={item.text}
        >
          <Search className="w-5 h-5" />
        </a>
      );
    }

    if (isDesktop) {
      return (
        <a
          href={item.link}
          class="text-xs md:text-sm font-bold text-gray-300 hover:text-[#FF6B35] transition-colors uppercase tracking-widest"
          data-i18n-key={`nav.${item.key}`}
        >
          {item.text}
        </a>
      );
    }

    return (
      <a
        href={item.link}
        class="flex items-center justify-between w-full py-4 px-4 text-lg font-black text-gray-100 hover:text-[#FF6B35] hover:bg-[#FF6B35]/10 transition-all border-b border-[#FF6B35]/10 last:border-0 uppercase tracking-wide"
        data-i18n-key={`nav.${item.key}`}
        @click="$dispatch('menu-close')"
      >
        <span>{item.text}</span>
        <ChevronDown className="w-5 h-5 -rotate-90 text-gray-500" />
      </a>
    );
  })}
</>
