---
import { SITE, LOGO_IMAGE } from '../../config';
import { Menu, X } from 'lucide-react';
import HeaderMobileMenu from './HeaderMobileMenu.astro';
import HeaderNavLinks from './HeaderNavLinks.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';

import { defaultLang, languages } from '../../i18n/ui';

const { nav, i18n } = SITE;
---

<header
  class="sticky top-0 z-50 w-full bg-[#1A1A1A]/95 backdrop-blur-md border-b border-[#FF6B35]/20 transition-colors duration-300"
  x-data={`{ mobileOpen: false, currentLang: '${defaultLang.toUpperCase()}' }`}
  x-init={`try { currentLang = (localStorage.getItem('preferred-lang') || '${defaultLang}').toUpperCase(); } catch (e) {} `}
  x-effect="document.body.classList.toggle('overflow-hidden', mobileOpen)"
  @keydown.escape.window="mobileOpen = false"
  @resize.window="if (window.innerWidth >= 768) mobileOpen = false"
  @menu-close.window="mobileOpen = false"
  @language-change.window="currentLang = (($event.detail && $event.detail.lang) ? $event.detail.lang : '${defaultLang}').toUpperCase()"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo & Name -->
      
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2 group">
          {LOGO_IMAGE.enable && SITE.logo && <img src={SITE.logo} alt="Logo" class="h-8 w-8 object-contain" />}

          <div class="flex flex-col sm:flex-row sm:items-end sm:gap-2 leading-tight">
            <span class="font-bold text-white text-lg leading-tight group-hover:text-[#FF6B35] transition-colors">
              {SITE.labName}
            </span>
          </div>
        </a>
      </div>

      <nav class="hidden md:flex gap-6 items-center">
        <HeaderNavLinks items={nav} mode="desktop" />
        {i18n.enabled && <LanguageSwitcher languages={languages} />}
      </nav>



      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 -mr-2 text-gray-300 hover:bg-[#FF6B35] rounded-lg transition-colors z-[80] relative"
        aria-label="Toggle menu"
        aria-controls="mobile-menu"
        x-bind:aria-expanded="mobileOpen.toString()"
        @click="mobileOpen = !mobileOpen"
      >
        <span class="icon-menu block transition-transform duration-300" :class="{ 'rotate-90 opacity-0': mobileOpen }">
          <Menu className="w-6 h-6" />
        </span>
        <span class="icon-close absolute inset-0 flex items-center justify-center transition-transform duration-300" :class="mobileOpen ? '' : 'hidden rotate-90'">
          <X className="w-6 h-6" />
        </span>
      </button>
    </div>
  </div>

  <HeaderMobileMenu
    nav={nav}
    i18nEnabled={i18n.enabled}
    languages={languages}
    logoEnabled={LOGO_IMAGE.enable}
    logoSrc={SITE.logo}
    labName={SITE.labName}
  />
</header>
