---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
---

<Layout title="Events">
  <div class="bg-[#0F0F0F] min-h-screen text-white pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-16">
          Events Calendar
        </h1>
        <p class="text-xl text-gray-300 mb-12">
          Stay up to date with our latest workshops, talks, and social gatherings.
        </p>
        
        <div class="flex justify-center">
          <div class="w-full max-w-[800px] aspect-[4/3] rounded-3xl overflow-hidden border border-white/10 shadow-2xl">
            <iframe 
              src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FChicago&showPrint=0&mode=AGENDA&showNav=0&showTabs=0&src=Y18xODUwYzIyZDFmYWM4YjA4YjU4NDdhM2Q0MTA4OWYyMDQ2Yzk0NmMyMWU1NjJiNjNlZmI1ZmIwODVlMTBjM2U5QGdyb3VwLmNhbGVuZGFyLmdvb2dsZS5jb20&color=%23616161" 
              style="border-width:0; filter: invert(90%) hue-rotate(180deg);" 
              width="100%" 
              height="100%" 
              frameborder="0" 
              scrolling="no"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
