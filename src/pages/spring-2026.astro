---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Spring 2026">
  <div class="bg-[#13294B] min-h-screen text-white pb-20">
    <!-- Header -->
    <section class="py-24 px-4 text-center pb-0">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-8">How to get involved in Spring 2026</h1>
      <p class="max-w-2xl mx-auto text-gray-200 text-lg mb-6 leading-relaxed px-4">
        We communicate primarily through Discord, so whether you are interested in AI Safety Fundamentals, technical aspects of AI Alignment, or AI-centered Sci-Fi, you should join our server :)
      </p>
      <div class="flex justify-center mb-16">
        <a href="https://discord.com/invite/hGcu53KNrY" target="_blank" class="inline-block bg-[#ff8c69] text-white font-bold py-3 px-8 rounded-full hover:bg-[#E84A27] transition-colors shadow-lg">
          Join the Discord!
        </a>
      </div>
    </section>

    <!-- Steps -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      
      <!-- Applications Row -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 border-b border-white/10 pb-16">
        <!-- Step 1: Course -->
        <div class="flex flex-col gap-6 items-start">
          <div>
            <h2 class="text-3xl font-bold text-[#ff8c69] leading-tight">Enter our AI Safety Fundamentals course</h2>
          </div>
          <div>
            <p class="text-gray-200 text-lg mb-6 leading-relaxed">
               A structured, beginner-friendly course that builds a shared foundation in AI safety, covering core concepts in governance, strategy, and major risk arguments through curated readings and guided discussion.
            </p>
            <a href="https://forms.gle/KmdGKUSHR94pj9MX9" target="_blank" class="inline-block bg-[#ff8c69] text-white font-bold py-3 px-8 rounded-full hover:bg-[#E84A27] transition-colors shadow-lg">
              Apply Now
            </a>
          </div>
        </div>

        <!-- Step 2: Fellowship -->
        <div class="flex flex-col gap-6 items-start">
          <div>
            <h2 class="text-3xl font-bold text-[#ff8c69] leading-tight">Apply to our AI Alignment Fellowship</h2>
          </div>
          <div>
            <p class="text-gray-200 text-lg mb-6 leading-relaxed">
               Fellows work through advanced material in small cohorts, implement the material they learn, and develop practical intuition around interpretability, evaluations, robustness, and scalable oversight.
            </p>
            <a href="https://forms.gle/YW19jBzE3x8XCAza7" target="_blank" class="inline-block bg-[#ff8c69] text-white font-bold py-3 px-8 rounded-full hover:bg-[#E84A27] transition-colors shadow-lg">
              Apply Now
            </a>
          </div>
        </div>
      </div>

      <!-- Step 3: SRC -->
      <div class="flex flex-col md:flex-row gap-8 items-start">
        <div class="md:w-1/3">
          <h2 class="text-3xl font-bold text-[#ff8c69] leading-tight">Join the Singularity Reading Club (SRC) events</h2>
        </div>
        <div class="md:w-2/3">
          <p class="text-gray-200 text-lg mb-6 leading-relaxed">
            We run regular reading discussions open to all that blend science fiction, philosophy, and AI research to think clearly about the long-run trajectory of technology and the risks of advanced AI. Alongside the readings, SRC hosts casual socials to build community, invites guest speakers for public conversations, and organizes workshops.
          </p>
        </div>
      </div>

    </section>
  </div>
</Layout>
