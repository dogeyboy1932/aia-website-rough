---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, BookOpen, Users, Sparkles, MessageCircle } from 'lucide-react';
import { GradientText, FadeIn } from '../components/AnimatedText';
import { FloatingOrbs } from '../components/AuroraBackground';
---

<Layout title="Spring 2026">
  <div class="relative min-h-screen text-white overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 pointer-events-none">
      <FloatingOrbs client:load />
    </div>

    <!-- Header Section -->
    <section class="relative py-24 px-4 text-center">
      <div class="max-w-4xl mx-auto">
        <FadeIn client:load>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#FF5F05]/10 border border-[#FF5F05]/30 mb-8">
            <Sparkles className="w-4 h-4 text-[#FF5F05]" />
            <span class="text-sm font-medium text-[#FF5F05] uppercase tracking-wider">Spring 2026</span>
          </div>
        </FadeIn>

        <FadeIn client:load delay={100}>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-8 uppercase tracking-tight">
            How to <GradientText client:load text="Get Involved" />
          </h1>
        </FadeIn>

        <FadeIn client:load delay={200}>
          <p class="max-w-2xl mx-auto text-gray-300 text-lg mb-8 leading-relaxed">
            We communicate primarily through Discord, so whether you are interested in AI Safety Fundamentals, technical aspects of AI Alignment, or AI-centered Sci-Fi, you should join our server :)
          </p>
        </FadeIn>

        <FadeIn client:load delay={300}>
          <a 
            href="https://discord.com/invite/hGcu53KNrY" 
            target="_blank" 
            class="btn-primary inline-flex items-center gap-3 group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1892.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.1023.2462.1922.3718.2914a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.699.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419z"/></svg>
            Join the Discord
            <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
          </a>
        </FadeIn>
      </div>
    </section>

    <!-- Programs Section -->
    <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 space-y-8">
      
      <!-- Applications Row -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- AI Safety Fundamentals -->
        <FadeIn client:load delay={100}>
          <div class="glass rounded-2xl overflow-hidden card-hover h-full">
            <div class="p-8 flex flex-col h-full">
              <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-[#FF5F05]/20">
                  <BookOpen className="w-6 h-6 text-[#FF5F05]" />
                </div>
                <span class="text-xs font-bold uppercase tracking-wider text-[#FF5F05] bg-[#FF5F05]/10 px-3 py-1 rounded-full">
                  Course
                </span>
              </div>
              
              <h2 class="text-2xl md:text-3xl font-black text-white mb-4 uppercase tracking-wide">
                AI Safety Fundamentals
              </h2>
              
              <p class="text-gray-400 text-lg mb-8 leading-relaxed flex-grow">
                A structured, beginner-friendly course that builds a shared foundation in AI safety, covering core concepts in governance, strategy, and major risk arguments through curated readings and guided discussion.
              </p>
              
              <a 
                href="https://forms.gle/KmdGKUSHR94pj9MX9" 
                target="_blank" 
                class="btn-primary inline-flex items-center justify-center gap-2 w-full group"
              >
                Apply Now
                <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
              </a>
            </div>
          </div>
        </FadeIn>

        <!-- AI Alignment Fellowship -->
        <FadeIn client:load delay={200}>
          <div class="glass rounded-2xl overflow-hidden card-hover h-full">
            <div class="p-8 flex flex-col h-full">
              <div class="flex items-center gap-4 mb-6">
                <div class="p-3 rounded-xl bg-[#FF5F05]/20">
                  <Users className="w-6 h-6 text-[#FF5F05]" />
                </div>
                <span class="text-xs font-bold uppercase tracking-wider text-[#FF9E1B] bg-[#FF9E1B]/10 px-3 py-1 rounded-full">
                  Fellowship
                </span>
              </div>
              
              <h2 class="text-2xl md:text-3xl font-black text-white mb-4 uppercase tracking-wide">
                AI Alignment Fellowship
              </h2>
              
              <p class="text-gray-400 text-lg mb-8 leading-relaxed flex-grow">
                Fellows work through advanced material in small cohorts, implement the material they learn, and develop practical intuition around interpretability, evaluations, robustness, and scalable oversight.
              </p>
              
              <a 
                href="https://forms.gle/YW19jBzE3x8XCAza7" 
                target="_blank" 
                class="btn-primary inline-flex items-center justify-center gap-2 w-full group"
              >
                Apply Now
                <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
              </a>
            </div>
          </div>
        </FadeIn>
      </div>

      <!-- Singularity Reading Club -->
      <FadeIn client:load delay={300}>
        <div class="glass rounded-2xl overflow-hidden card-hover">
          <div class="p-8 md:p-10">
            <div class="flex flex-col md:flex-row gap-8">
              <div class="md:w-1/3 flex flex-col items-start">
                <div class="flex items-center gap-4 mb-6">
                  <div class="p-3 rounded-xl bg-[#FF5F05]/20">
                    <MessageCircle className="w-6 h-6 text-[#FF5F05]" />
                  </div>
                  <span class="text-xs font-bold uppercase tracking-wider text-[#13294B] bg-[#13294B]/20 px-3 py-1 rounded-full border border-[#13294B]/30">
                    Reading Club
                  </span>
                </div>
                
                <h2 class="text-2xl md:text-3xl font-black text-white uppercase tracking-wide">
                  Singularity Reading Club
                </h2>
              </div>
              
              <div class="md:w-2/3">
                <p class="text-gray-400 text-lg leading-relaxed">
                  We run regular reading discussions open to all that blend science fiction, philosophy, and AI research to think clearly about the long-run trajectory of technology and the risks of advanced AI. Alongside the readings, SRC hosts casual socials to build community, invites guest speakers for public conversations, and organizes workshops.
                </p>
                
                <div class="mt-6 flex flex-wrap gap-3">
                  <span class="px-3 py-1 text-sm rounded-full bg-[#13294B]/30 text-gray-300 border border-[#13294B]/30">
                    Science Fiction
                  </span>
                  <span class="px-3 py-1 text-sm rounded-full bg-[#13294B]/30 text-gray-300 border border-[#13294B]/30">
                    Philosophy
                  </span>
                  <span class="px-3 py-1 text-sm rounded-full bg-[#13294B]/30 text-gray-300 border border-[#13294B]/30">
                    AI Research
                  </span>
                  <span class="px-3 py-1 text-sm rounded-full bg-[#FF5F05]/10 text-[#FF5F05] border border-[#FF5F05]/30">
                    Open to All
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </FadeIn>
    </section>
  </div>
</Layout>
