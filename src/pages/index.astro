---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ChevronDown, ArrowRight, Sparkles, Shield, Brain, Zap } from 'lucide-react';
import { SITE } from '../config';
import { GradientText, SplitText, FadeIn } from '../components/AnimatedText';
import { FloatingOrbs, ParticleField } from '../components/AuroraBackground';
import FocusAreaCard from '../components/FocusAreaCard.astro';

const papers = (await getCollection('publications'))
  .filter(p => p.data.type === 'paper' && p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 z-0">
      <FloatingOrbs client:load />
      <ParticleField client:load particleCount={40} color="#FF5F05" />

      {SITE.hero.image ? (
        <img
          class="w-full h-full object-cover opacity-90"
          src={SITE.hero.image}
          alt={SITE.hero.title}
          loading="eager"
          decoding="sync"
        />
      ) : null}

      <!-- Gradient overlays -->
      <div class="absolute inset-0 bg-gradient-to-b from-[#0A0F1A] via-[#0A0F1A]/80 to-[#0A0F1A]"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0A0F1A] via-transparent to-[#0A0F1A]/50"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 sm:px-8 lg:px-16 py-16 lg:py-0 h-full lg:flex lg:items-center">
      <div class="w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- LEFT: Title -->
        <div class="flex flex-col gap-6">
          <!-- <FadeIn client:load delay={0}>
            <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-[#FF5F05]/10 border border-[#FF5F05]/25 w-fit">
              <Sparkles className="w-4 h-4 text-[#FF5F05] shrink-0" />
              <span class="text-xs font-semibold text-[#FF5F05] uppercase tracking-[0.15em]">University of Illinois</span>
            </div>
          </FadeIn> -->

          <FadeIn client:load delay={0}>
            <h1 class="text-5xl sm:text-6xl lg:text-[4.5rem] xl:text-[5.25rem] font-black text-white leading-[1.1] tracking-tight pb-2">
              AI Alignment
              <GradientText client:load text="@ Illinois" animate={true} />
            </h1>
          </FadeIn>
        </div>

        <!-- RIGHT: Subtitle + CTAs + Stats -->
        <div class="flex flex-col gap-8">

          <!-- Subtitle -->
          <FadeIn client:load delay={240}>
            <p class="text-xl sm:text-2xl text-gray-400 leading-relaxed">
              A community of{' '}
              <span class="text-[#FF5F05] font-semibold">researchers</span>,{' '}
              <span class="text-[#FF9E1B] font-semibold">philosophers</span>, and{' '}
              <span class="text-[#FF5F05] font-semibold">builders</span>{' '}
              focused on safe, aligned, and human‑centered artificial intelligence.
            </p>
          </FadeIn>

          <!-- CTAs -->
          <FadeIn client:load delay={320}>
            <div class="flex flex-row items-center gap-4">
              <a href="/spring-2026" class="btn-primary flex items-center gap-2 group px-8 py-4 text-base font-semibold rounded-lg">
                Join Now
                <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" />
              </a>
              <a href="/team" class="btn-secondary flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-lg">
                Meet the Team
              </a>
            </div>
          </FadeIn>

          <!-- Stats -->
          <!-- <FadeIn client:load delay={420}>
            <div class="pt-6 border-t border-white/8 grid grid-cols-3 gap-0">
              <div class="pr-8">
                <div class="text-4xl lg:text-5xl font-black text-[#FF5F05] glow-orange leading-none">3</div>
                <div class="text-xs text-gray-500 uppercase tracking-[0.12em] mt-3 font-medium">Programs</div>
              </div>
              <div class="px-8 border-x border-white/8">
                <div class="text-4xl lg:text-5xl font-black text-[#FF5F05] glow-orange leading-none">50+</div>
                <div class="text-xs text-gray-500 uppercase tracking-[0.12em] mt-3 font-medium">Members</div>
              </div>
              <div class="pl-8">
                <div class="text-4xl lg:text-5xl font-black text-[#FF5F05] glow-orange leading-none">UIUC</div>
                <div class="text-xs text-gray-500 uppercase tracking-[0.12em] mt-3 font-medium">Based</div>
              </div>
            </div>
          </FadeIn> -->

        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <div class="p-2.5 rounded-full border border-[#FF5F05]/20 text-[#FF5F05]/50">
        <ChevronDown className="w-5 h-5" />
      </div>
    </div>
  </section>

  <!-- Our Foci Section -->
  <section class="relative py-32 lg:py-40 overflow-hidden">
    <!-- Background decoration -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 right-0 w-96 h-96 rounded-full opacity-10" style="background: radial-gradient(circle, rgba(255, 95, 5, 0.5) 0%, transparent 70%); filter: blur(80px);"></div>
      <div class="absolute bottom-1/4 left-0 w-80 h-80 rounded-full opacity-20" style="background: radial-gradient(circle, rgba(19, 41, 75, 0.6) 0%, transparent 70%); filter: blur(60px);"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 sm:px-8 lg:px-12">

      <!-- Section Header -->
      <FadeIn client:load>
        <div class="text-center mb-20">
          <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white uppercase tracking-tight leading-none mb-5">
            Our <GradientText client:load text="Focus Areas" />
          </h2>
          <!-- <p class="text-gray-500 text-lg max-w-xl mx-auto leading-relaxed">
            Exploring the critical challenges in AI safety through education, research, and community
          </p> -->
        </div>
      </FadeIn>

      <!-- Accordion Items -->
      <div class="grid grid-cols-1 gap-5">

        <!-- Item 1 -->
        <FadeIn client:load delay={100}>
          <FocusAreaCard title="Governance, Safety & Strategy" open={true}>
            <Shield slot="icon" className="w-5 h-5 text-[#FF5F05]" />
            <ChevronDown slot="chevron" className="w-5 h-5" />
            Our <strong class="text-[#FF5F05] font-semibold">Foundations of AI Safety</strong> certification course introduces the governance and strategy landscape around advanced AI: how institutions, incentives, and policy shape risk, and which levers might actually reduce catastrophic outcomes.
          </FocusAreaCard>
        </FadeIn>

        <!-- Item 2 -->
        <FadeIn client:load delay={200}>
          <FocusAreaCard title="Technical Alignment">
            <Brain slot="icon" className="w-5 h-5 text-[#FF5F05]" />
            <ChevronDown slot="chevron" className="w-5 h-5" />
            In our <strong class="text-[#FF5F05] font-semibold">Alignment Fellowship</strong>, we dive deep into technical approaches to alignment, including interpretability, robustness, evaluations, and scalable oversight. Our goal is to distinctively model detailed threat scenarios and build the practical competence needed to make AI systems safe and reliable.
          </FocusAreaCard>
        </FadeIn>

        <!-- Item 3 -->
        <FadeIn client:load delay={300}>
          <FocusAreaCard title="X-Risk & Long-Term Impact">
            <Zap slot="icon" className="w-5 h-5 text-[#FF5F05]" />
            <ChevronDown slot="chevron" className="w-5 h-5" />
            We explore the long-run trajectory of technology and the potential catastrophic risks of advanced AI. Our <strong class="text-[#FF5F05] font-semibold">Singularity Reading Club (SRC)</strong> draws from science fiction and philosophy to understand the scale of the challenge and the urgency of meaningful action.
          </FocusAreaCard>
        </FadeIn>

      </div>

      <!-- CTA -->
      <FadeIn client:load delay={400}>
        <div class="mt-16 text-center">
          <a href="/spring-2026" class="btn-primary inline-flex items-center gap-2.5 group px-8 py-4">
            Spring 2026
            <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" />
          </a>
        </div>
      </FadeIn>

    </div>
  </section>
</Layout>