---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { ChevronDown } from 'lucide-react';
import { SITE } from '../config';

const papers = (await getCollection('publications'))
  .filter(p => p.data.type === 'paper' && p.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      {SITE.hero.image ? (
        <img
          class="w-full h-full object-cover"
          src={SITE.hero.image}
          alt={SITE.hero.title}
          loading="eager"
          decoding="sync"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-[#0F0F0F] to-[#1A1A1A]"></div>
      )}
      <!-- Dark Gradient Overlay for Readability -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#0F0F0F]/95 via-[#0F0F0F]/70 to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <div class="max-w-3xl text-left">
        <h1 class="text-5xl font-extrabold text-white sm:text-6xl md:text-7xl mb-6 shadow-none leading-tight tracking-tight">
          {SITE.hero.title}
        </h1>
        <p class="mt-4 text-xl text-gray-300 sm:max-w-2xl md:text-2xl leading-relaxed">
          {SITE.hero.subtitle}
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/spring-2026" class="flex items-center justify-center px-8 py-4 bg-[#FF6B35] text-white text-lg font-bold uppercase tracking-wider border border-[#FF6B35] hover:shadow-[0_0_30px_rgba(255,107,53,0.6),inset_0_0_20px_rgba(255,107,53,0.2)] transition-all duration-300 shadow-[0_0_20px_rgba(255,107,53,0.3)]">
            Join Now
          </a>
          <a href="/about" class="flex items-center justify-center px-8 py-4 border-2 border-[#FF6B35] text-lg font-bold uppercase tracking-wider text-white hover:shadow-[0_0_30px_rgba(255,107,53,0.4),inset_0_0_20px_rgba(255,107,53,0.1)] transition-all duration-300 backdrop-blur-sm">
            About
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce text-[#FF6B35]/50">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <!-- Our Foci Section -->
  <section class="py-20 bg-[#1A1A1A] text-white border-t border-[#FF6B35]/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-5xl md:text-6xl font-black text-white mb-16 uppercase tracking-tight glow-orange-lg">Our Foci</h2>

      <div class="space-y-4">
        <!-- Item 1 -->
        <details class="group border-b border-[#FF6B35]/30 pb-4" open>
            <summary class="flex justify-between items-center py-6 cursor-pointer list-none text-2xl md:text-3xl font-black text-gray-100 hover:text-[#FF6B35] transition-colors uppercase tracking-wide">
                <span>Governance, Safety & Strategy</span>
                <span class="transition-transform group-open:rotate-180">
                    <ChevronDown className="w-8 h-8" />
                </span>
            </summary>
            <div class="pb-8 text-lg text-gray-400 leading-relaxed">
                Our <strong class="text-gray-100">Foundations of AI Safety</strong> certification course introduces the governance and strategy landscape around advanced AI: how institutions, incentives, and policy shape risk, and which levers might actually reduce catastrophic outcomes.
            </div>
        </details>

        <!-- Item 2 -->
        <details class="group border-b border-[#FF6B35]/30 pb-4">
            <summary class="flex justify-between items-center py-6 cursor-pointer list-none text-2xl md:text-3xl font-black text-gray-100 hover:text-[#FF6B35] transition-colors uppercase tracking-wide">
                <span>Technical Alignment</span>
                <span class="transition-transform group-open:rotate-180">
                    <ChevronDown className="w-8 h-8" />
                </span>
            </summary>
            <div class="pb-8 text-lg text-gray-400 leading-relaxed">
                In our <strong class="text-gray-100">Alignment Fellowship</strong>, we dive deep into technical approaches to alignment, including interpretability, robustness, evaluations, and scalable oversight. Our goal is to distinctively model detailed threat scenarios and build the practical competence needed to make AI systems safe and reliable.
            </div>
        </details>

        <!-- Item 3 -->
        <details class="group border-b border-[#FF6B35]/30 pb-4">
            <summary class="flex justify-between items-center py-6 cursor-pointer list-none text-2xl md:text-3xl font-black text-gray-100 hover:text-[#FF6B35] transition-colors uppercase tracking-wide">
                <span>X-Risk & Long-Term Impact</span>
                <span class="transition-transform group-open:rotate-180">
                    <ChevronDown className="w-8 h-8" />
                </span>
            </summary>
            <div class="pb-8 text-lg text-gray-400 leading-relaxed">
                We explore the long-run trajectory of technology and the potential catastrophic risks of advanced AI. Our <strong class="text-gray-100">Singularity Reading Club (SRC)</strong> draws from science fiction and philosophy to understand the scale of the challenge and the urgency of meaningful action.
            </div>
        </details>
      </div>

      <div class="mt-16 text-center">
        <a href="/spring-2026" class="inline-flex items-center justify-center px-8 py-4 bg-[#FF6B35] text-white text-lg font-bold uppercase tracking-wider border border-[#FF6B35] hover:shadow-[0_0_30px_rgba(255,107,53,0.6),inset_0_0_20px_rgba(255,107,53,0.2)] transition-all duration-300 shadow-[0_0_20px_rgba(255,107,53,0.3)]">
            Spring 2026 Information
        </a>
      </div>
    </div>
  </section>
</Layout>
