---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resources">
  <div class="bg-[#0F0F0F] min-h-screen text-white pb-20">
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-20">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-12 text-center">Resources</h1>
      
      <div class="space-y-12 text-gray-400">
        <div>
          <h3 class="text-2xl font-bold text-[#FF6B35] mb-4">Organizations</h3>
          <ul class="list-disc pl-5 space-y-2 text-lg">
            <li>Aggregated list: <a href="https://www.aisafety.com/" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">aisafety.com</a></li>
            <li>Kairos: <a href="https://kairos-project.org/" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">kairos-project.org</a></li>
            <li>SPAR: <a href="https://sparai.org/" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">sparai.org</a></li>
          </ul>
        </div>

         <div>
          <h3 class="text-2xl font-bold text-[#FF6B35] mb-4">Reading List</h3>
          <ul class="list-disc pl-5 space-y-2 text-lg">
             <li>Superintelligence: Paths, Dangers, and Strategies by Nick Bostrom</li>
             <li>Gödel, Escher, Bach: an Eternal Golden Braid by Douglas Hofstadter</li>
             <li>The Last Question (short story) by Isaac Asimov</li>
             <li>Nick Bostrom essays: <a href="https://nickbostrom.com/" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">nickbostrom.com</a></li>
             <li>AI 2027 forecast: <a href="https://ai-2027.com/" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">ai-2027.com</a></li>
             <li>The Network State: <a href="https://thenetworkstate.com/" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">thenetworkstate.com</a></li>
          </ul>
        </div>

        <div>
           <h3 class="text-2xl font-bold text-[#FF6B35] mb-4">Podcasts & Channels</h3>
           <ul class="list-disc pl-5 space-y-2 text-lg">
             <li><a href="https://open.spotify.com/playlist/2UV0dokGfpfQ9e29aeKcSO" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">Philosophy podcasts on Spotify</a></li>
             <li><a href="https://youtube.com/playlist?list=PLrAXtmErZgOdP_8GztsuKi9nrraNbKKp4" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">Lex Fridman Podcast</a></li>
             <li><a href="https://youtube.com/@ycombinator" class="text-[#FF6B35] hover:underline hover:text-white transition-colors" target="_blank">Y Combinator startup school</a></li>
           </ul>
        </div>
      </div>
    </section>
  </div>
</Layout>
