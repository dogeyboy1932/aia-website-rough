---
import type { CollectionEntry } from 'astro:content';
import { Mail } from 'lucide-react';
import { FaLinkedin, FaDiscord } from 'react-icons/fa6';

interface Props {
  member: CollectionEntry<'team'>;
}

const { member } = Astro.props;
const { name, title, avatar, email, discord, linkedin } = member.data;

const TEAM_AVATAR_PUBLIC_DIR = '/assets/TeamPfps';
const avatarSrc = avatar ? `${TEAM_AVATAR_PUBLIC_DIR}/${avatar}` : undefined;
const discordHandle = discord?.replace(/^@/, '');
const discordHref = discord
  ? discord.startsWith('http')
    ? discord
    : `https://discord.com/users/${encodeURIComponent(discordHandle ?? '')}`
  : undefined;
---

<div class="glass rounded-2xl p-6 card-hover w-full max-w-sm">
  <div class="flex flex-col items-center text-center">
    <!-- Avatar Container -->
    <div class="relative w-52 h-52 mb-6 group">
      <div class="absolute inset-0 rounded-full bg-gradient-to-br from-[#FF5F05] to-[#FF9E1B] opacity-20 blur-xl group-hover:opacity-40 transition-opacity duration-300"></div>
      <div class="relative w-full h-full rounded-full overflow-hidden border-2 border-[#FF5F05]/30 group-hover:border-[#FF5F05]/60 transition-colors duration-300">
        {avatarSrc ? (
          <img
            src={avatarSrc}
            alt={name}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[#13294B] to-[#1E3A5F] text-[#FF5F05] text-3xl font-bold">
            {name.split(' ').map(n => n[0]).join('').substring(0, 2)}
          </div>
        )}
      </div>
    </div>

    <!-- Info -->
    <div class="mb-3 flex items-center justify-center gap-2">
      <h3 class="text-xl font-bold text-white group-hover:text-[#FF5F05] transition-colors">
        {name}
      </h3>
    </div>
    
    {title && (
      <div class="mb-4">
        <span class="text-lg font-medium text-[#FF5F05] tracking-wide px-3 py-1 rounded-full bg-[#FF5F05]/10 border border-[#FF5F05]/20">
          {title}
        </span>
      </div>
    )}

    <!-- Social Links -->
    <div class="flex flex-col items-center gap-2 w-full">
      <div class="flex items-center gap-3 mt-1">
        {discord && discord !== '#' && discordHref && (
          <a
            href={discordHref}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-[#5865F2] transition-colors duration-200"
            aria-label={`${name}'s Discord`}
          >
            <FaDiscord className="w-5 h-5" />
          </a>
        )}

        {linkedin && linkedin !== '#' && (
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-[#0A66C2] transition-colors duration-200"
            aria-label={`${name}'s LinkedIn`}
          >
            <FaLinkedin className="w-5 h-5" />
          </a>
        )}

        {email && (
          <a 
            href={`mailto:${email}`} 
            class="flex items-center gap-2 text-lg text-gray-400 hover:text-[#FF5F05] transition-colors duration-200 group/link"
          >
            <Mail className="w-4 h-4" />
            <span class="group-hover/link:underline">{email}</span>
          </a>
        )}
      </div>
    </div>
  </div>
</div>
