---

import type { CollectionEntry } from 'astro:content';

import EmailSvg from './EmailSvg.astro';
import { Mail } from 'lucide-react';

import { Image } from 'astro:assets';

interface Props {
  member: CollectionEntry<'team'>;
}

const { member } = Astro.props;
const { name, title, avatar, email, discord } = member.data;
---

<div class="flex flex-col items-center text-center">
  <!-- Avatar Container -->
  <div class="relative w-48 h-48 mb-4 rounded-full overflow-hidden bg-gray-100 border-4 border-white/10 flex items-center justify-center shadow-lg">
    <!-- Using a div wrapper instead of link since individual team pages might not be needed/supported with reduced schema -->
    <div class="block w-full h-full">
      {avatar ? (
        <Image 
          src={avatar} 
          alt={name} 
          class="w-full h-full object-cover transition-transform duration-500" 
          width={400}
          height={400}
          format="webp"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-[#13294B] text-[#ff8c69] text-4xl font-bold">
          {name.split(' ').map(n => n[0]).join('').substring(0, 2)}
        </div>
      )}
    </div>
  </div>

  <!-- Info -->
  <div class="mb-2">
    <h3 class="text-xl font-bold text-[#ff8c69]">{name}</h3>
  </div>
  
  {title && (
    <div class="flex justify-center px-2">
        <span class="text-sm font-medium opacity-90 tracking-wide">
          {title}
        </span>
    </div>
  )}

  <!-- Social Links -->
  <div class="flex flex-col items-center gap-1">
      {discord && discord !== '#' && (
        <div class="flex items-center gap-2 text-sm text-gray-400">
           <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1892.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.1023.2462.1922.3718.2914a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.699.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.419-2.1568 2.419z"/></svg>
           <span>{discord}</span>
        </div>
      )}
      {email && (
        <div class="flex items-center gap-2 text-sm text-gray-400 h-[20px]">
          <Mail className="w-4 h-4" />
          <div class="flex items-center"><EmailSvg email={email} /></div>
        </div>
      )}
  </div>
</div>
