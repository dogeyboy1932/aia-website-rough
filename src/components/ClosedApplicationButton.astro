---
interface Props {
  label?: string;
  message?: string;
}

const {
  label = 'Apply Now',
  message = 'Applications are CLOSED for this semester. Please apply next semester. Meanwhile, join the discord to stay updated on our events!',
} = Astro.props;
---

<div class="relative group z-50 w-full overflow-visible">
  <button
    type="button"
    class="btn-primary inline-flex items-center justify-center gap-2 w-full opacity-70 cursor-not-allowed"
    aria-describedby="applications-closed-message"
    aria-disabled="true"
    disabled
  >
    {label}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M3 10a1 1 0 011-1h9.586L10.293 5.707a1 1 0 011.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 01-1-1z" clip-rule="evenodd" />
    </svg>
  </button>

  <div
    id="applications-closed-message"
    role="status"
    class="pointer-events-none absolute right-0 top-full z-[9999] mt-2 w-72 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-800 shadow-2xl opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100"
  >
    {message}
  </div>
</div>
